# Application Environment
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=music_platform
DB_USERNAME=root
DB_PASSWORD=

# SQLite Configuration (alternative)
SQLITE_PATH=database/music.sqlite

# Authentication
AUTH_SESSION_LIFETIME=7200

# File Upload
UPLOAD_MAX_SIZE=10485760 # 10MB
UPLOAD_ALLOWED_TYPES=mp3,wav,ogg,mp4,m4a
UPLOAD_PATH=storage/uploads

# Audio Preview
PREVIEW_DURATION=10 # seconds for unregistered users

# Email Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Music Platform"

# Slack Webhook
SLACK_WEBHOOK_URL=

# API Keys
API_KEY=

# Logging
LOG_CHANNEL=file
LOG_LEVEL=debug
LOG_PATH=storage/logs